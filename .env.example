# Copy to .env (gitignored) for local dev, and set the same vars in
# Vercel → Project → Settings → Environment Variables for production/preview.
#
# ⚠️  This file is COMMITTED to git. Put ONLY placeholders here — never real keys.
#     Real secrets go in .env (gitignored).

# ── Supabase — auth + database + storage ──────────────────────────────────────
# Dashboard (app.supabase.com) → Settings → API → Project URL + anon/public key.
# VITE_ vars are baked into the browser bundle at build time (safe — the anon
# key is meant to be public); SUPABASE_SERVICE_KEY is server-only, never expose it.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ── Server-side only — never expose in the React bundle ──────────────────────

# Claude "director" — writes the cinematic video prompt
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — premium AI voiceovers (voice library + text-to-speech)
ELEVENLABS_API_KEY=sk_...

# Higgsfield — video + image generation (platform.higgsfield.ai). Two
# credentials, not a single bearer token. Either the pair below, or a combined
# "key:secret" as HIGGSFIELD_API_TOKEN.
HIGGSFIELD_API_KEY=your-higgsfield-key-id
HIGGSFIELD_SECRET=your-higgsfield-key-secret
# HIGGSFIELD_API_TOKEN=your-key-id:your-key-secret

# Google Gemini — fallback image model (turnaround sheets, edits) when
# Higgsfield credentials above are not set. Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# Optional: override the image model (default: gemini-2.5-flash-image)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Google Veo 3 — fallback video model (same Gemini API key) when Higgsfield
# credentials are not set.
# VEO_MODEL=veo-3.0-fast-generate-001
# VEO_ASPECT_RATIO=9:16

# ── Discovery Engine (optional) ───────────────────────────────────────────────
# When unset, /api/discover serves a curated demo dataset so the full clone flow
# works without external accounts.
#
# APIFY_TOKEN powers THREE actors through one token:
#   • apify/facebook-ads-scraper                     — live Meta Ad Library search
#   • thirdwatch/aliexpress-product-scraper          — keyword sourcing (enabled)
#   • freecamp008/aliexpress-search-by-image-actor   — image sourcing  (enabled)
# All three are enabled; their input field names are verified. Inspect any
# actor's live schema with: GET /api/sourcing?schema=meta (also ali-keyword,
# ali-image). AliExpress dataset OUTPUT fields are parsed defensively — if a run
# returns no usable match, sourcing reports "couldn't verify" (never a fake price).
# APIFY_TOKEN=apify_api_...
#
# CJ Dropshipping fulfillment handoff (separate concern from the AliExpress
# price-check). Either a full affiliate referral URL, or a bare ref code that
# gets appended to the CJ search link. Leave unset to link to a plain CJ search.
# CJ_AFFILIATE_URL=https://cjdropshipping.com/?ref=...
