# Copy to .env (gitignored) for local `netlify dev`, and set the same vars in
# Netlify → Site settings → Environment variables for production.
#
# ⚠️  This file is COMMITTED to git. Put ONLY placeholders here — never real keys.
#     Real secrets go in .env (gitignored).

# ── Clerk auth (https://clerk.com → create application → API Keys) ────────────
# VITE_ prefix is required — this is the public publishable key, safe to expose.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# In Clerk dashboard → Paths, set Sign-in URL = /sign-in, Sign-up = /sign-up

# ── Supabase database ─────────────────────────────────────────────────────────
# Dashboard (app.supabase.com) → Settings → API → Project URL + anon/public key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Server-side only — never expose in the React bundle ──────────────────────

# Claude "director" — writes the cinematic video prompt
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — premium AI voiceovers (voice library + text-to-speech)
ELEVENLABS_API_KEY=sk_...

# Google Gemini — image model for turnaround model sheets (nano-banana).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# Optional: override the image model (default: gemini-2.5-flash-image)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ── Video provider ────────────────────────────────────────────────────────────
# Switch between providers without touching code.
#   higgsfield  (default) — platform.higgsfield.ai
#   arcads                — external-api.arcads.ai
VIDEO_PROVIDER=higgsfield

# Higgsfield image-to-video. Either set the pair below…
HF_API_KEY=your-higgsfield-key-id
HF_API_SECRET=your-higgsfield-key-secret
# …or the combined form instead (one or the other):
# HF_CREDENTIALS=your-key-id:your-key-secret

# Arcads AI (set VIDEO_PROVIDER=arcads to activate)
ARCADS_API_KEY=your-arcads-api-key
# Optional: pin a specific Arcads model instead of using the quality-tier defaults.
# Models: sora2 | sora2-pro | veo31 | kling-2.6 | kling-3.0 | grok-video | seedance-2.0
# ARCADS_MODEL=kling-3.0

# ── Discovery Engine (optional) ───────────────────────────────────────────────
# When unset, /api/discover serves a curated demo dataset so the full clone flow
# works without external accounts.
#
# APIFY_TOKEN powers THREE actors through one token:
#   • apify/facebook-ads-scraper                     — live Meta Ad Library search
#   • thirdwatch/aliexpress-product-scraper          — keyword sourcing (gated off)
#   • freecamp008/aliexpress-search-by-image-actor   — image sourcing  (gated off)
# The two AliExpress actors are DISABLED in api/sourcing.ts until their input/
# output field names are verified. Verify each with:
#   GET /api/apify-schema?actor=meta   (also: ali-keyword, ali-image)
# then correct the adapter's input()/mapItem() and flip `enabled: true`.
# APIFY_TOKEN=apify_api_...
#
# CJ Dropshipping fulfillment handoff (separate concern from the AliExpress
# price-check). Either a full affiliate referral URL, or a bare ref code that
# gets appended to the CJ search link. Leave unset to link to a plain CJ search.
# CJ_AFFILIATE_URL=https://cjdropshipping.com/?ref=...
